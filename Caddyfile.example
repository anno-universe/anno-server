{
    grace_period 10s
}

:80 {
    # Health check handled by Caddy directly (no Django dependency)
    @health path /health/
    respond @health "OK" 200

    # ---- Backend: proxy API / admin / static / media to Django ----
    # These MUST NOT fall through to the SPA try_files rewrite, otherwise
    # POST /api/* gets rewritten to /index.html and file_server returns 405.
    handle /api/* {
        reverse_proxy anno-server:8000 {
            header_up Host {http.request.host}
            header_up X-Forwarded-For {http.request.remote.host}
            header_up X-Forwarded-Proto {http.request.scheme}
            header_up X-Forwarded-Host {http.request.host}
            header_up X-Forwarded-Port {http.request.port}
        }
    }

    handle /admin/* {
        reverse_proxy anno-server:8000 {
            header_up Host {http.request.host}
            header_up X-Forwarded-For {http.request.remote.host}
            header_up X-Forwarded-Proto {http.request.scheme}
            header_up X-Forwarded-Host {http.request.host}
            header_up X-Forwarded-Port {http.request.port}
        }
    }

    handle /static/* {
        reverse_proxy anno-server:8000 {
            header_up Host {http.request.host}
            header_up X-Forwarded-For {http.request.remote.host}
            header_up X-Forwarded-Proto {http.request.scheme}
            header_up X-Forwarded-Host {http.request.host}
            header_up X-Forwarded-Port {http.request.port}
        }
    }

    handle /media/* {
        reverse_proxy anno-server:8000 {
            header_up Host {http.request.host}
            header_up X-Forwarded-For {http.request.remote.host}
            header_up X-Forwarded-Proto {http.request.scheme}
            header_up X-Forwarded-Host {http.request.host}
            header_up X-Forwarded-Port {http.request.port}
        }
    }

    # ---- Frontend: SPA fallback, only for paths not handled above ----
    handle {
        root * /srv/anno-web
        try_files {path} /index.html
        file_server
    }

    log {
        output stdout
        format json
    }
}
