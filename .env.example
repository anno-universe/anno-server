# Django
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=false
ALLOWED_HOSTS=localhost,example.com

# Timezone
TZ=Asia/Shanghai

# Optional: interactive session token TTL in seconds (default 1800)
# INTERACTIVE_SESSION_TOKEN_TTL_SECONDS=1800

# Interactive inference provider (anno-sam) — see docker-compose.example.yml.
# The browser reaches it via Caddy's /_interactive_infer route; set the provider
# record's public_url = /_interactive_infer and inference_url = http://anno-sam:8422.
# PROVIDER_API_KEY=changeme          # shared secret; also the provider's auth_secret
# AUTH_HEADER=X-API-Key              # provider auth_param_name (server -> service)
# SAM_MODEL_ID=facebook/sam-vit-base
# HF_CACHE_DIR=./hf-cache            # weights cache (point to external storage if desired)
